# The Desk local environment template.
# Do not paste real secrets into chat or commit a populated .env file.

## BLOCKING
# OKX demo credentials. Use demo / simulated-trading keys only.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_API_PASSPHRASE=
OKX_PASSPHRASE=
OKX_DEMO=1

# Execution defaults for the sprint.
EXECUTION_MODE=fixture
MAX_NOTIONAL_USD=200
DAILY_NOTIONAL_CAP_USD=1000
INSTRUMENT_ALLOWLIST=BTC-USDT,ETH-USDT,SOL-USDT,USDC-USDT
KILL_SWITCH_GLOBAL=false

## STRETCH
# Reasoning and data enrichments; every path must have deterministic fallback.
ANTHROPIC_API_KEY=
ETHERSCAN_API_KEY=
CRYPTOPANIC_TOKEN=

# X Layer testnet anchor inputs from the sprint plan.
X_LAYER_TESTNET_RPC=https://testrpc.xlayer.tech/terigon
X_LAYER_TESTNET_CHAIN_ID=1952
X_LAYER_DEPLOYER_PK=
X_LAYER_SESSION_ANCHOR_ADDR=
OKLINK_API_KEY=

# Current repo compatibility aliases referenced by the Vite/npm prototype.
DESK_OKX_MODE=fixture
DESK_API_PORT=4181
DESK_WEB_PORT=4173
DESK_XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
DESK_XLAYER_CHAIN_ID=1952
DESK_XLAYER_ANCHOR_PRIVATE_KEY=
DESK_XLAYER_SESSION_ANCHOR_ADDRESS=
DESK_XLAYER_ANCHOR_TX_HASH=
DESK_SPRINT_AUDIT_NETWORK=
SECRETS_SETUP_PORT=4180

## FORBIDDEN
# Never use an OKX API key with withdraw permission for this project.
# Leave broadcast-enabling flags empty unless a later gate explicitly changes scope.
LIVE_BROADCAST_CONFIRM=
DESK_XLAYER_ALLOW_MAINNET=
