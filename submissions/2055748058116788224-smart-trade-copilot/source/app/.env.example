# Copy to .env and fill in a PERSONAL OKX key.
# The shared hackathon key is rate-limited; a personal key removes the cap.
# Get one at: https://web3.okx.com/onchain-os/dev-portal
#
# .env is gitignored — never commit your real key.

# Variable names must match the OKX Developer Portal exactly:
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Optional: pin a specific onchainos binary path
# ONCHAINOS_BIN=C:\Users\you\.local\bin\onchainos.exe
