# Copy to .env.local for local dev, OR set these in Vercel project env vars.
# All are SERVER-SIDE only — never exposed to the browser.

# OpenAI key for the autonomous agent layer (dynamic tool-calling).
# Without it, the app honestly falls back to a deterministic sweep.
OPENAI_API_KEY=

# Optional model override (default: gpt-4o-mini)
# STC_MODEL=gpt-4o-mini

# Deployed demo: force curated fixtures so the public URL always works
# even though Vercel has no onchainos binary. Set to 1 on Vercel.
STC_FORCE_DEMO=1

# Local fully-live mode instead: leave STC_FORCE_DEMO unset and provide a
# personal OKX onchainOS key (https://web3.okx.com/onchain-os/dev-portal).
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=
# ONCHAINOS_BIN=C:\Users\you\.local\bin\onchainos.exe
