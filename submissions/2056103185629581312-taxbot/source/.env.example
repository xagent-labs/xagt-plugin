# TaxBot Environment Configuration
# Copy this to .env and fill in your values

# OKX API Credentials (read-only key recommended)
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Optional: OKX Demo/Sandbox mode (set to true for testing)
OKX_DEMO=false

# X Layer Audit Trail (optional - wallet private key to sign the ledger hash tx)
# WARNING: Use a dedicated wallet with minimal OKB for gas only
XLAYER_PRIVATE_KEY=your_private_key_here

# Tax year to process
TAX_YEAR=2025
