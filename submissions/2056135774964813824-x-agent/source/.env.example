# X-Agent — Autonomous AI Crypto Intelligence
  # Copy to .env.local and fill in. Only OpenRouter is required.

  # REQUIRED — OpenRouter API key (https://openrouter.ai)
  OPENROUTER_API_KEY=

  # OPTIONAL — Default model (any OpenRouter slug). Gemini 2.0 Flash is
  # ~10× cheaper than Claude Haiku and streams well for research/chat.
  OPENROUTER_MODEL=google/gemini-2.0-flash-001

  # OPTIONAL — App attribution shown in the OpenRouter dashboard
  OPENROUTER_REFERER=https://x-agent.local
  OPENROUTER_TITLE=X-Agent