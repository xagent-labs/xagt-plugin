# ── Server ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────────────────────
# Default: sqlite:///rugwatch.db in the backend directory
# DATABASE_URL=sqlite:///rugwatch.db

# ── OKX OnchainOS API credentials ──────────────────────────────────────────
# Get yours at https://web3.okx.com/onchain-os/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_API_PASSPHRASE=
OKX_PROJECT_ID=

# ── Monitoring ──────────────────────────────────────────────────────────────
DEFAULT_CHAIN=xlayer
POLL_INTERVAL=60

# ── Exit Safety Rails ──────────────────────────────────────────────────────
MAX_LOSS_PCT=50
MAX_SLIPPAGE=0.5
KILL_SWITCH=false
DRY_RUN=false

# ── Auth ────────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=24
